# Секреты для подключения к Confluence.
# Не коммить этот файл с реальными значениями.

confluence:
  # Тип авторизации:
  # - api_token -> Cloud API token или server bearer/basic token workflow
  # - basic     -> классический логин + пароль
  auth_type: "api_token"

  # Имя пользователя или email.
  # Для Atlassian Cloud обычно нужен email.
  # Для bearer token режима можно не указывать.
  username: "user@example.com"

  # API token.
  # Для Atlassian Cloud обычно используется именно этот вариант.
  # Если auth_type=api_token и username задан, клиент отправит basic auth:
  #   username + api_token
  # Если auth_type=api_token и username не задан, клиент отправит:
  #   Authorization: Bearer <token>
  api_token: "your-api-token"

  # Пример для basic auth:
  #
  # auth_type: "basic"
  # username: "my-login"
  # password: "my-password"
