{
  "mcpServers": {
    "confluence-mcp": {
      "command": ".venv-mcp/bin/python",
      "args": [
        "-m",
        "confluence_pagecreator_mcp"
      ],
      "env": {
        "PAGECREATOR_CONFIG_PATH": "config/app.yaml",
        "PAGECREATOR_SECRETS_PATH": "secrets/confluence.yaml"
      }
    }
  }
}
